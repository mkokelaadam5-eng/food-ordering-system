<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Track Order - FoodHub</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <!-- Navigation Bar -->
    <nav class="navbar">
        <div class="navbar-container">
            <a href="/" class="navbar-brand">🍕 FoodHub</a>
            <ul class="navbar-links">
                <li><a href="/">Home</a></li>
                <li><a href="/menu">Menu</a></li>
                <li><a href="/about">About</a></li>
                <li><a href="/contact">Contact</a></li>
            </ul>
            <div class="navbar-icons">
                <a href="/cart" title="Shopping Cart">
                    <i class="fas fa-shopping-cart"></i>
                    <span class="cart-badge" style="display: none;">0</span>
                </a>
                <a href="/admin" title="Admin Dashboard">
                    <i class="fas fa-cog"></i>
                </a>
            </div>
        </div>
    </nav>

    <!-- Order Tracking Section -->
    <section class="container section-padding">
        <div class="section-header">
            <h2>Track Your Order</h2>
            <p>Real-time updates on your delivery status</p>
        </div>

        <div class="tracking-container">
            <div id="tracking-result">
                <p style="text-align: center; padding: 2rem;">Loading order details...</p>
            </div>
            
            <div style="text-align: center; margin-top: 2rem;">
                <a href="/menu" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> Continue Shopping
                </a>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer>
        <div class="container">
            <div>
                <h4>🍕 FoodHub</h4>
                <p>Your trusted platform for food delivery</p>
            </div>
            <div>
                <h4>Quick Links</h4>
                <a href="/menu">Menu</a>
                <a href="/about">About Us</a>
                <a href="/contact">Contact</a>
            </div>
            <div>
                <h4>Company</h4>
                <a href="#">Privacy Policy</a>
                <a href="#">Terms of Service</a>
            </div>
            <div>
                <h4>Support</h4>
                <p>Email: support@foodhub.com</p>
                <p>Phone: +1 (555) 123-4567</p>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; 2024 FoodHub. All rights reserved.</p>
        </div>
    </footer>

    <script src="/js/app.js"></script>
</body>
</html>
