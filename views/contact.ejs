<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact Us - FoodHub</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <!-- Navigation Bar -->
    <nav class="navbar">
        <div class="navbar-container">
            <a href="/" class="navbar-brand">🍕 FoodHub</a>
            <ul class="navbar-links">
                <li><a href="/">Home</a></li>
                <li><a href="/menu">Menu</a></li>
                <li><a href="/about">About</a></li>
                <li><a href="/contact">Contact</a></li>
            </ul>
            <div class="navbar-icons">
                <a href="/cart" title="Shopping Cart">
                    <i class="fas fa-shopping-cart"></i>
                    <span class="cart-badge" style="display: none;">0</span>
                </a>
                <a href="/admin" title="Admin Dashboard">
                    <i class="fas fa-cog"></i>
                </a>
            </div>
        </div>
    </nav>

    <!-- Contact Section -->
    <section class="container section-padding">
        <div class="section-header">
            <h2>Contact Us</h2>
            <p>We'd love to hear from you. Send us a message!</p>
        </div>

        <div class="contact-container">
            <!-- Contact Form -->
            <form class="contact-form" onsubmit="submitContact(event)">
                <h3 style="margin-bottom: 1.5rem;">Send us a Message</h3>
                
                <div class="form-group">
                    <label for="contact-name">Full Name</label>
                    <input type="text" id="contact-name" name="name" required>
                </div>

                <div class="form-group">
                    <label for="contact-email">Email Address</label>
                    <input type="email" id="contact-email" name="email" required>
                </div>

                <div class="form-group">
                    <label for="contact-phone">Phone Number (Optional)</label>
                    <input type="tel" id="contact-phone" name="phone">
                </div>

                <div class="form-group">
                    <label for="contact-subject">Subject</label>
                    <input type="text" id="contact-subject" name="subject" required>
                </div>

                <div class="form-group">
                    <label for="contact-message">Message</label>
                    <textarea id="contact-message" name="message" required></textarea>
                </div>

                <button type="submit" class="btn btn-primary" style="width: 100%; padding: 0.75rem;">
                    <i class="fas fa-paper-plane"></i> Send Message
                </button>
            </form>

            <!-- Contact Information -->
            <div class="contact-info">
                <h3 style="margin-bottom: 1.5rem;">Get in Touch</h3>
                
                <div class="contact-info-item">
                    <div class="contact-info-label">
                        <i class="fas fa-map-marker-alt"></i> Address
                    </div>
                    <div class="contact-info-value">
                        123 Food Street, Restaurant Quarter<br>
                        City, State 12345<br>
                        Country
                    </div>
                </div>

                <div class="contact-info-item">
                    <div class="contact-info-label">
                        <i class="fas fa-phone"></i> Phone
                    </div>
                    <div class="contact-info-value">
                        +1 (555) 123-4567<br>
                        Available 24/7
                    </div>
                </div>

                <div class="contact-info-item">
                    <div class="contact-info-label">
                        <i class="fas fa-envelope"></i> Email
                    </div>
                    <div class="contact-info-value">
                        support@foodhub.com<br>
                        orders@foodhub.com
                    </div>
                </div>

                <div class="contact-info-item">
                    <div class="contact-info-label">
                        <i class="fas fa-clock"></i> Business Hours
                    </div>
                    <div class="contact-info-value">
                        Monday - Sunday<br>
                        10:00 AM - 11:00 PM
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer>
        <div class="container">
            <div>
                <h4>🍕 FoodHub</h4>
                <p>Your trusted platform for food delivery</p>
            </div>
            <div>
                <h4>Quick Links</h4>
                <a href="/menu">Menu</a>
                <a href="/about">About Us</a>
                <a href="/contact">Contact</a>
            </div>
            <div>
                <h4>Company</h4>
                <a href="#">Privacy Policy</a>
                <a href="#">Terms of Service</a>
            </div>
            <div>
                <h4>Support</h4>
                <p>Email: support@foodhub.com</p>
                <p>Phone: +1 (555) 123-4567</p>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; 2024 FoodHub. All rights reserved.</p>
        </div>
    </footer>

    <script src="/js/app.js"></script>
</body>
</html>
