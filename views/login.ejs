<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - FoodHub</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <!-- Navigation Bar -->
    <nav class="navbar">
        <div class="navbar-container">
            <a href="/" class="navbar-brand">🍕 FoodHub</a>
            <ul class="navbar-links">
                <li><a href="/">Home</a></li>
                <li><a href="/menu">Menu</a></li>
                <li><a href="/about">About</a></li>
                <li><a href="/contact">Contact</a></li>
            </ul>
            <div class="navbar-icons">
                <a href="/cart" title="Shopping Cart">
                    <i class="fas fa-shopping-cart"></i>
                    <span class="cart-badge" style="display: none;">0</span>
                </a>
                <a href="/register" title="Register">
                    <i class="fas fa-user-plus"></i>
                </a>
            </div>
        </div>
    </nav>

    <!-- Login Section -->
    <section class="container section-padding">
        <div class="auth-container">
            <div class="auth-card">
                <div class="auth-header">
                    <h1>Welcome Back!</h1>
                    <p>Sign in to your FoodHub account</p>
                </div>

                <!-- Success Message -->
                <% if (success) { %>
                    <div class="alert alert-success">
                        <i class="fas fa-check-circle"></i> <%= success %>
                    </div>
                <% } %>

                <!-- Error Message -->
                <% if (error) { %>
                    <div class="alert alert-error">
                        <i class="fas fa-exclamation-circle"></i> <%= error %>
                    </div>
                <% } %>

                <!-- Login Form -->
                <form method="POST" action="/login" class="auth-form">
                    <div class="form-group">
                        <label for="email">
                            <i class="fas fa-envelope"></i> Email Address
                        </label>
                        <input 
                            type="email" 
                            id="email" 
                            name="email" 
                            placeholder="example@email.com"
                            required
                            autofocus
                        >
                    </div>

                    <div class="form-group">
                        <label for="password">
                            <i class="fas fa-lock"></i> Password
                        </label>
                        <input 
                            type="password" 
                            id="password" 
                            name="password" 
                            placeholder="Enter your password"
                            required
                        >
                    </div>

                    <button type="submit" class="btn btn-primary" style="width: 100%; margin-top: 1rem;">
                        <i class="fas fa-sign-in-alt"></i> Sign In
                    </button>
                </form>

                <!-- Demo Credentials -->
                <div class="demo-section">
                    <p style="font-weight: 600; margin-bottom: 0.75rem;">🔐 Demo Admin Account:</p>
                    <div class="demo-credentials">
                        <p><strong>Email:</strong> admin@foodhub.com</p>
                        <p><strong>Password:</strong> admin123</p>
                    </div>
                </div>

                <!-- Link to Register -->
                <div class="auth-footer">
                    <p>Don't have an account? 
                        <a href="/register" class="auth-link">Create one here</a>
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer>
        <div class="container">
            <div>
                <h4>🍕 FoodHub</h4>
                <p>Your trusted platform for food delivery</p>
            </div>
            <div>
                <h4>Quick Links</h4>
                <a href="/menu">Menu</a>
                <a href="/about">About Us</a>
                <a href="/contact">Contact</a>
            </div>
            <div>
                <h4>Company</h4>
                <a href="#">Privacy Policy</a>
                <a href="#">Terms of Service</a>
            </div>
            <div>
                <h4>Support</h4>
                <p>Email: support@foodhub.com</p>
                <p>Phone: +1 (555) 123-4567</p>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; 2024 FoodHub. All rights reserved.</p>
        </div>
    </footer>

    <script src="/js/app.js"></script>
</body>
</html>
