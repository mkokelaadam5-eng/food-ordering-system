<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Shopping Cart - FoodHub</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <!-- Navigation Bar -->
    <nav class="navbar">
        <div class="navbar-container">
            <a href="/" class="navbar-brand">🍕 FoodHub</a>
            <ul class="navbar-links">
                <li><a href="/">Home</a></li>
                <li><a href="/menu">Menu</a></li>
                <li><a href="/about">About</a></li>
                <li><a href="/contact">Contact</a></li>
            </ul>
            <div class="navbar-icons">
                <a href="/cart" title="Shopping Cart">
                    <i class="fas fa-shopping-cart"></i>
                    <span class="cart-badge" style="display: none;">0</span>
                </a>
                <a href="/admin" title="Admin Dashboard">
                    <i class="fas fa-cog"></i>
                </a>
            </div>
        </div>
    </nav>

    <!-- Cart Section -->
    <section class="container section-padding">
        <div class="section-header">
            <h2>Shopping Cart</h2>
        </div>

        <div class="cart-container">
            <div class="cart-items" id="cart-items">
                <p style="text-align: center; padding: 2rem;">Your cart is empty</p>
            </div>

            <div class="cart-summary">
                <h3>Order Summary</h3>
                <div style="margin: 1.5rem 0; padding: 1.5rem 0; border-top: 1px solid var(--border-color); border-bottom: 1px solid var(--border-color);">
                    <div class="summary-row">
                        <span>Subtotal:</span>
                        <span id="summary-total">$0.00</span>
                    </div>
                    <div class="summary-row">
                        <span>Delivery Fee:</span>
                        <span>$2.00</span>
                    </div>
                    <div class="summary-row">
                        <span>Tax (10%):</span>
                        <span id="summary-tax">$0.00</span>
                    </div>
                </div>
                <div class="summary-row total">
                    <span>Total:</span>
                    <span id="total-amount">$0.00</span>
                </div>
                <a href="/checkout" class="btn btn-primary" style="width: 100%; text-align: center; margin-top: 1rem;">
                    Proceed to Checkout <i class="fas fa-arrow-right"></i>
                </a>
                <a href="/menu" class="btn btn-secondary" style="width: 100%; text-align: center; margin-top: 0.5rem;">
                    Continue Shopping
                </a>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer>
        <div class="container">
            <div>
                <h4>🍕 FoodHub</h4>
                <p>Your trusted platform for food delivery</p>
            </div>
            <div>
                <h4>Quick Links</h4>
                <a href="/menu">Menu</a>
                <a href="/about">About Us</a>
                <a href="/contact">Contact</a>
            </div>
            <div>
                <h4>Company</h4>
                <a href="#">Privacy Policy</a>
                <a href="#">Terms of Service</a>
            </div>
            <div>
                <h4>Support</h4>
                <p>Email: support@foodhub.com</p>
                <p>Phone: +1 (555) 123-4567</p>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; 2024 FoodHub. All rights reserved.</p>
        </div>
    </footer>

    <script>
        // Update cart summary totals
        function updateSummary() {
            const subtotal = parseFloat(document.getElementById('summary-total').textContent.slice(1)) || 0;
            const tax = (subtotal * 0.1).toFixed(2);
            const delivery = 2.00;
            const total = (subtotal + parseFloat(tax) + delivery).toFixed(2);
            
            document.getElementById('summary-tax').textContent = '$' + tax;
            document.getElementById('total-amount').textContent = '$' + total;
        }
        
        // Initial update
        document.addEventListener('DOMContentLoaded', updateSummary);
        
        // Watch for cart changes
        const observer = new MutationObserver(updateSummary);
        observer.observe(document.getElementById('summary-total'), { childList: true, characterData: true, subtree: true });
    </script>
    <script src="/js/app.js"></script>
</body>
</html>
