<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard - FoodHub</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <!-- Navigation Bar -->
    <nav class="navbar">
        <div class="navbar-container">
            <a href="/" class="navbar-brand">🍕 FoodHub Admin</a>
            <ul class="navbar-links">
                <li><a href="/">Home</a></li>
                <li><a href="/admin">Dashboard</a></li>
            </ul>
            <div class="navbar-icons">
                <a href="/" title="Back to Store">
                    <i class="fas fa-home"></i>
                </a>
            </div>
        </div>
    </nav>

    <!-- Admin Section -->
    <section class="container section-padding">
        <div class="section-header">
            <h2>Admin Dashboard</h2>
            <p>Manage menu items and view all orders</p>
        </div>

        <div class="admin-container">
            <!-- Add Menu Item Section -->
            <div class="admin-section">
                <h3>🍔 Add New Menu Item</h3>
                <form id="add-menu-form" style="margin-top: 1.5rem;">
                    <div class="form-group">
                        <label for="item-name">Item Name</label>
                        <input type="text" id="item-name" name="name" required>
                    </div>

                    <div class="form-group">
                        <label for="item-category">Category</label>
                        <select id="item-category" name="category" required>
                            <option value="">-- Select Category --</option>
                            <option value="Main Dishes">Main Dishes</option>
                            <option value="Snacks">Snacks</option>
                            <option value="Drinks">Drinks</option>
                            <option value="Desserts">Desserts</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="item-price">Price ($)</label>
                        <input type="number" id="item-price" name="price" step="0.01" min="0" required>
                    </div>

                    <div class="form-group">
                        <label for="item-description">Description</label>
                        <textarea id="item-description" name="description"></textarea>
                    </div>

                    <div class="form-group">
                        <label for="item-image">Image URL</label>
                        <input type="text" id="item-image" name="image" placeholder="https://source.unsplash.com/400x300/?food">
                    </div>

                    <button type="submit" class="btn btn-primary" style="width: 100%;">
                        <i class="fas fa-plus"></i> Add Item
                    </button>
                </form>
            </div>

            <!-- Menu Items Management Section -->
            <div class="admin-section">
                <h3>📄 Manage Menu Items</h3>
                <div style="margin-top: 1.5rem; overflow-x: auto;">
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Name</th>
                                <th>Category</th>
                                <th>Price</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody id="menu-items-list">
                            <tr>
                                <td colspan="5" style="text-align: center; padding: 2rem;">Loading...</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Orders Section -->
        <div class="admin-section" style="margin-top: 2rem;">
            <h3>📑 All Orders</h3>
            <div style="margin-top: 1.5rem; overflow-x: auto;">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>Order ID</th>
                            <th>Customer</th>
                            <th>Total</th>
                            <th>Status</th>
                            <th>Date</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody id="orders-list">
                        <tr>
                            <td colspan="6" style="text-align: center; padding: 2rem;">Loading...</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer>
        <div class="container">
            <div>
                <h4>🍕 FoodHub</h4>
                <p>Your trusted platform for food delivery</p>
            </div>
            <div>
                <h4>Quick Links</h4>
                <a href="/menu">Menu</a>
                <a href="/about">About Us</a>
                <a href="/contact">Contact</a>
            </div>
            <div>
                <h4>Company</h4>
                <a href="#">Privacy Policy</a>
                <a href="#">Terms of Service</a>
            </div>
            <div>
                <h4>Support</h4>
                <p>Email: support@foodhub.com</p>
                <p>Phone: +1 (555) 123-4567</p>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; 2024 FoodHub. All rights reserved.</p>
        </div>
    </footer>

    <script>
        // Load menu items
        function loadMenuItems() {
            fetch('/api/menu')
                .then(response => response.json())
                .then(items => {
                    const tbody = document.getElementById('menu-items-list');
                    if (items.length === 0) {
                        tbody.innerHTML = '<tr><td colspan="5" style="text-align: center; padding: 2rem;">No menu items</td></tr>';
                        return;
                    }
                    
                    let html = '';
                    items.forEach(item => {
                        html += `
                            <tr>
                                <td>${item.id}</td>
                                <td>${item.name}</td>
                                <td>${item.category}</td>
                                <td>$${item.price.toFixed(2)}</td>
                                <td>
                                    <div class="admin-actions">
                                        <button class="btn btn-danger btn-sm" onclick="deleteMenuItem(${item.id})" style="padding: 0.4rem 0.8rem; font-size: 0.8rem;">
                                            <i class="fas fa-trash"></i> Delete
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        `;
                    });
                    tbody.innerHTML = html;
                })
                .catch(error => console.error('Error loading menu items:', error));
        }

        // Load orders
        function loadOrders() {
            fetch('/api/admin/orders')
                .then(response => response.json())
                .then(orders => {
                    const tbody = document.getElementById('orders-list');
                    if (orders.length === 0) {
                        tbody.innerHTML = '<tr><td colspan="6" style="text-align: center; padding: 2rem;">No orders yet</td></tr>';
                        return;
                    }
                    
                    let html = '';
                    orders.forEach(order => {
                        const date = new Date(order.created_at).toLocaleDateString();
                        html += `
                            <tr>
                                <td><strong>${order.id.substring(0, 8)}...</strong></td>
                                <td>${order.customer_name}</td>
                                <td>$${order.total_price.toFixed(2)}</td>
                                <td>
                                    <select onchange="updateOrderStatus('${order.id}', this.value)" style="padding: 0.5rem; border: 1px solid var(--border-color); border-radius: 0.25rem;">
                                        <option value="Pending" ${order.status === 'Pending' ? 'selected' : ''}>Pending</option>
                                        <option value="Preparing" ${order.status === 'Preparing' ? 'selected' : ''}>Preparing</option>
                                        <option value="On the way" ${order.status === 'On the way' ? 'selected' : ''}>On the way</option>
                                        <option value="Delivered" ${order.status === 'Delivered' ? 'selected' : ''}>Delivered</option>
                                    </select>
                                </td>
                                <td>${date}</td>
                                <td>
                                    <button class="btn btn-secondary btn-sm" onclick="viewOrderDetails('${order.id}')" style="padding: 0.4rem 0.8rem; font-size: 0.8rem;">
                                        <i class="fas fa-eye"></i> View
                                    </button>
                                </td>
                            </tr>
                        `;
                    });
                    tbody.innerHTML = html;
                })
                .catch(error => console.error('Error loading orders:', error));
        }

        // Delete menu item
        function deleteMenuItem(itemId) {
            if (!confirm('Are you sure you want to delete this item?')) return;
            
            fetch(`/api/admin/menu/${itemId}`, { method: 'DELETE' })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        showNotification('Menu item deleted successfully', 'success');
                        loadMenuItems();
                    } else {
                        showNotification('Failed to delete item', 'error');
                    }
                })
                .catch(error => console.error('Error:', error));
        }

        // Update order status
        function updateOrderStatus(orderId, status) {
            fetch(`/api/orders/${orderId}/status`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ status })
            })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        showNotification('Order status updated', 'success');
                        loadOrders();
                    } else {
                        showNotification('Failed to update status', 'error');
                    }
                })
                .catch(error => console.error('Error:', error));
        }

        // View order details
        function viewOrderDetails(orderId) {
            alert('Order ID: ' + orderId + '\n\nFull details can be viewed in the database.');
        }

        // Add menu item form submission
        document.getElementById('add-menu-form').addEventListener('submit', function(e) {
            e.preventDefault();
            
            const formData = {
                name: document.getElementById('item-name').value,
                category: document.getElementById('item-category').value,
                price: document.getElementById('item-price').value,
                description: document.getElementById('item-description').value,
                image: document.getElementById('item-image').value
            };
            
            fetch('/api/admin/menu/add', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(formData)
            })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        showNotification('Menu item added successfully', 'success');
                        document.getElementById('add-menu-form').reset();
                        loadMenuItems();
                    } else {
                        showNotification('Failed to add item', 'error');
                    }
                })
                .catch(error => console.error('Error:', error));
        });

        // Initialize
        document.addEventListener('DOMContentLoaded', () => {
            loadMenuItems();
            loadOrders();
        });
    </script>
    <script src="/js/app.js"></script>
</body>
</html>
