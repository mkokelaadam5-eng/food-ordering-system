<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FoodHub - Order Delicious Food Online</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <!-- Navigation Bar -->
    <nav class="navbar">
        <div class="navbar-container">
            <a href="/" class="navbar-brand">🍕 FoodHub</a>
            <ul class="navbar-links">
                <li><a href="/">Home</a></li>
                <li><a href="/menu">Menu</a></li>
                <li><a href="/about">About</a></li>
                <li><a href="/contact">Contact</a></li>
            </ul>
            <div class="navbar-icons">
                <a href="/cart" title="Shopping Cart">
                    <i class="fas fa-shopping-cart"></i>
                    <span class="cart-badge" style="display: none;">0</span>
                </a>
                <a href="/admin" title="Admin Dashboard">
                    <i class="fas fa-cog"></i>
                </a>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="hero">
        <div class="hero-content">
            <h1>Welcome to FoodHub</h1>
            <p>Order delicious food from your favorite local restaurants delivered right to your doorstep</p>
            <a href="/menu" class="btn btn-primary" style="font-size: 1.1rem; padding: 1rem 2rem;">
                Order Now <i class="fas fa-arrow-right"></i>
            </a>
        </div>
    </section>

    <!-- Features Section -->
    <section class="container section-padding">
        <div class="section-header">
            <h2>Why Choose FoodHub?</h2>
        </div>
        <div class="menu-grid">
            <div class="menu-item" style="text-align: center;">
                <div style="font-size: 3rem; margin-bottom: 1rem;">⚡</div>
                <h3>Fast Delivery</h3>
                <p>Get your order delivered in 30-45 minutes</p>
            </div>
            <div class="menu-item" style="text-align: center;">
                <div style="font-size: 3rem; margin-bottom: 1rem;">🍽️</div>
                <h3>Fresh Food</h3>
                <p>All items are freshly prepared by our expert chefs</p>
            </div>
            <div class="menu-item" style="text-align: center;">
                <div style="font-size: 3rem; margin-bottom: 1rem;">💰</div>
                <h3>Best Prices</h3>
                <p>Competitive pricing with amazing discounts</p>
            </div>
            <div class="menu-item" style="text-align: center;">
                <div style="font-size: 3rem; margin-bottom: 1rem;">👍</div>
                <h3>Customer Support</h3>
                <p>24/7 support to help with your orders</p>
            </div>
        </div>
    </section>

    <!-- Testimonials Section -->
    <section class="container section-padding" style="background-color: var(--light-bg); border-radius: 0.75rem;">
        <div class="section-header">
            <h2>What Our Customers Say</h2>
        </div>
        <div class="testimonials-slider">
            <div class="testimonial-card">
                <div class="stars">★★★★★</div>
                <div class="testimonial-text">"FoodHub has completely changed how I order food. The app is user-friendly and the food always arrives hot and fresh!"</div>
                <div class="testimonial-author">- Ahmad Malove</div>
            </div>
            <div class="testimonial-card">
                <div class="stars">★★★★★</div>
                <div class="testimonial-text">"Excellent service! The variety of food options is amazing and the delivery team is always professional and punctual."</div>
                <div class="testimonial-author">- Rehema Nchimbi</div>
            </div>
            <div class="testimonial-card">
                <div class="stars">★★★★★</div>
                <div class="testimonial-text">"Best food ordering system I've used. Great prices, amazing food quality, and the order tracking is very helpful!"</div>
                <div class="testimonial-author">- Romelu Lukaku</div>
            </div>
        </div>
    </section>

    <!-- Call to Action -->
    <section class="container section-padding" style="text-align: center;">
        <h2 style="margin-bottom: 1rem;">Ready to Order?</h2>
        <p style="margin-bottom: 2rem; font-size: 1.1rem;">Browse our delicious menu and place your order today!</p>
        <a href="/menu" class="btn btn-primary" style="font-size: 1.1rem; padding: 1rem 2rem;">
            Explore Menu <i class="fas fa-utensils"></i>
        </a>
    </section>

    <!-- Footer -->
    <footer>
        <div class="container">
            <div>
                <h4>🍕 FoodHub</h4>
                <p>Your trusted platform for food delivery</p>
                <p style="margin-top: 1rem;">
                    <a href="#" style="margin-right: 1rem;"><i class="fab fa-facebook"></i></a>
                    <a href="#" style="margin-right: 1rem;"><i class="fab fa-twitter"></i></a>
                    <a href="#" style="margin-right: 1rem;"><i class="fab fa-instagram"></i></a>
                </p>
            </div>
            <div>
                <h4>Quick Links</h4>
                <a href="/menu">Menu</a>
                <a href="/about">About Us</a>
                <a href="/contact">Contact</a>
                <a href="/">Home</a>
            </div>
            <div>
                <h4>Company</h4>
                <a href="#">Privacy Policy</a>
                <a href="#">Terms of Service</a>
                <a href="#">FAQs</a>
                <a href="#">Blog</a>
            </div>
            <div>
                <h4>Support</h4>
                <p>Email: support@foodhub.com</p>
                <p>Phone: +1 (555) 123-4567</p>
                <p>Available 24/7</p>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; 2024 FoodHub. All rights reserved. | Designed with <i class="fas fa-heart" style="color: var(--primary-color);"></i> by our team</p>
        </div>
    </footer>

    <script src="/js/app.js"></script>
</body>
</html>
