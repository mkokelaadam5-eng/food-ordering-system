<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FoodHub - Order Delicious Food Online</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <!-- Navigation Bar -->
    <nav class="navbar">
        <div class="navbar-container">
            <a href="/" class="navbar-brand">🍕 FoodHub</a>
            <ul class="navbar-links">
                <li><a href="/">Home</a></li>
                <li><a href="/menu">Menu</a></li>
                <li><a href="/about">About</a></li>
                <li><a href="/contact">Contact</a></li>
            </ul>
            <div class="navbar-icons">
                <a href="/cart" title="Shopping Cart">
                    <i class="fas fa-shopping-cart"></i>
                    <span class="cart-badge" style="display: none;">0</span>
                </a>
                <% if (user) { %>
                    <div class="navbar-user-menu">
                        <span class="navbar-user-name">
                            <i class="fas fa-user-circle"></i> <%= user.name %>
                        </span>
                        <% if (user.role === 'admin') { %>
                            <a href="/admin" title="Admin Dashboard" style="text-decoration: none;">
                                <i class="fas fa-cog"></i>
                            </a>
                        <% } %>
                        <a href="/logout" title="Logout" style="text-decoration: none;">
                            <i class="fas fa-sign-out-alt"></i>
                        </a>
                    </div>
                <% } else { %>
                    <a href="/login" title="Login">
                        <i class="fas fa-user"></i>
                    </a>
                <% } %>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="hero">
        <div class="hero-content">
            <h1>Welcome to FoodHub 🍕</h1>
            <p>Order your favorite food and get it delivered hot and fresh!</p>
            <a href="/menu" class="btn btn-primary" style="font-size: 1.1rem;">
                <i class="fas fa-utensils"></i> Browse Menu
            </a>
        </div>
    </section>

    <!-- Featured Section -->
    <section class="container section-padding">
        <div class="section-header">
            <h2>🌟 Why Choose FoodHub?</h2>
        </div>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 2rem;">
            <div style="text-align: center;">
                <i style="font-size: 3rem; color: var(--primary-color);
 class="fas fa-lightning"></i>
                <h3>Fast Delivery</h3>
                <p>Get your food delivered in 30 minutes or it's free!</p>
            </div>
            <div style="text-align: center;">
                <i style="font-size: 3rem; color: var(--primary-color);" class="fas fa-shield-alt"></i>
                <h3>Safe & Secure</h3>
                <p>Your payment and personal data are always protected</p>
            </div>
            <div style="text-align: center;">
                <i style="font-size: 3rem; color: var(--primary-color);" class="fas fa-hand-holding-heart"></i>
                <h3>Quality Assured</h3>
                <p>Only the freshest ingredients in every meal</p>
            </div>
            <div style="text-align: center;">
                <i style="font-size: 3rem; color: var(--primary-color);" class="fas fa-dollar-sign"></i>
                <h3>Best Prices</h3>
                <p>Great discounts and special offers every day</p>
            </div>
        </div>
    </section>

    <!-- Popular Dishes -->
    <section class="container section-padding" style="background-color: var(--light-bg);">
        <div class="section-header">
            <h2>🍴 Popular Dishes</h2>
        </div>
        <div class="menu-grid" id="featured-menu">
            <!-- Featured items will be loaded here -->
        </div>
        <div style="text-align: center; margin-top: 2rem;">
            <a href="/menu" class="btn btn-primary">
                <i class="fas fa-arrow-right"></i> View Full Menu
            </a>
        </div>
    </section>

    <!-- Testimonials Section -->
    <section class="container section-padding">
        <div class="section-header">
            <h2>⭐ What Our Customers Say</h2>
        </div>
        <div class="testimonials-slider">
            <div class="testimonial-card">
                <div class="stars">★★★★★</div>
                <p class="testimonial-text">"Amazing food quality and super fast delivery! I'm ordering from FoodHub every week now."</p>
                <p class="testimonial-author">- Ahmad Malove</p>
            </div>
            <div class="testimonial-card">
                <div class="stars">★★★★★</div>
                <p class="testimonial-text">"Best online food ordering platform I've used. Great customer service and delicious food!"</p>
                <p class="testimonial-author">- Rehema Nchimbi</p>
            </div>
            <div class="testimonial-card">
                <div class="stars">★★★★★</div>
                <p class="testimonial-text">"Highly recommend FoodHub! Fresh food, reasonable prices, and excellent delivery service."</p>
                <p class="testimonial-author">- Romelu Lukaku</p>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section style="background: linear-gradient(135deg, var(--primary-color) 0%, var(--secondary-color) 100%); color: white; padding: 4rem 2rem; text-align: center;">
        <div class="container">
            <h2 style="color: white; margin-bottom: 1rem;">Ready to Order? 🚀</h2>
            <p style="color: rgba(255, 255, 255, 0.9); font-size: 1.1rem; margin-bottom: 2rem;">
                Browse our delicious menu and place your order now!
            </p>
            <a href="/menu" class="btn" style="background-color: white; color: var(--primary-color); font-weight: 600; font-size: 1.1rem;">
                <i class="fas fa-shopping-bag"></i> Start Ordering
            </a>
        </div>
    </section>

    <!-- Footer -->
    <footer>
        <div class="container">
            <div>
                <h4>🍕 FoodHub</h4>
                <p>Your trusted platform for food delivery</p>
            </div>
            <div>
                <h4>Quick Links</h4>
                <a href="/menu">Menu</a>
                <a href="/about">About Us</a>
                <a href="/contact">Contact</a>
            </div>
            <div>
                <h4>Company</h4>
                <a href="#">Privacy Policy</a>
                <a href="#">Terms of Service</a>
            </div>
            <div>
                <h4>Support</h4>
                <p>Email: support@foodhub.com</p>
                <p>Phone: +1 (555) 123-4567</p>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; 2024 FoodHub. All rights reserved.</p>
        </div>
    </footer>

    <script src="/js/app.js"></script>
    <script>
        // Load featured menu items on homepage
        document.addEventListener('DOMContentLoaded', () => {
            fetch('/api/menu')
                .then(response => response.json())
                .then(items => {
                    // Get first 6 items
                    const featured = items.slice(0, 6);
                    const grid = document.getElementById('featured-menu');
                    
                    let html = '';
                    featured.forEach(item => {
                        html += `
                            <div class="menu-item">
                                <img src="${item.image}" alt="${item.name}" class="menu-item-image">
                                <div class="menu-item-content">
                                    <div class="menu-item-category">${item.category}</div>
                                    <div class="menu-item-name">${item.name}</div>
                                    <div class="menu-item-description">${item.description || 'Delicious food item'}</div>
                                    <div class="menu-item-footer">
                                        <div class="menu-item-price">$${item.price.toFixed(2)}</div>
                                        <button class="btn btn-primary" onclick="addToCart(${item.id}, '${item.name}', ${item.price})">Add to Cart</button>
                                    </div>
                                </div>
                            </div>
                        `;
                    });
                    
                    grid.innerHTML = html;
                })
                .catch(error => console.error('Error loading featured items:', error));
        });
    </script>
</body>
</html>
