<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>About Us - FoodHub</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <!-- Navigation Bar -->
    <nav class="navbar">
        <div class="navbar-container">
            <a href="/" class="navbar-brand">🍕 FoodHub</a>
            <ul class="navbar-links">
                <li><a href="/">Home</a></li>
                <li><a href="/menu">Menu</a></li>
                <li><a href="/about">About</a></li>
                <li><a href="/contact">Contact</a></li>
            </ul>
            <div class="navbar-icons">
                <a href="/cart" title="Shopping Cart">
                    <i class="fas fa-shopping-cart"></i>
                    <span class="cart-badge" style="display: none;">0</span>
                </a>
                <a href="/admin" title="Admin Dashboard">
                    <i class="fas fa-cog"></i>
                </a>
            </div>
        </div>
    </nav>

    <!-- About Section -->
    <section class="container section-padding">
        <div class="section-header">
            <h2>About FoodHub</h2>
        </div>
        
        <div style="background-color: var(--light-bg); padding: 3rem; border-radius: 0.75rem; margin-bottom: 3rem;">
            <h3>Our Story</h3>
            <p>FoodHub was founded in 2020 with a mission to revolutionize the way people order food online. We believe that everyone deserves access to delicious, fresh food delivered conveniently to their doorstep.</p>
            
            <p>Starting as a small local delivery service, we've grown to become one of the most trusted food ordering platforms in the region. Our commitment to quality, speed, and customer satisfaction has earned us the loyalty of thousands of customers.</p>
            
            <h3 style="margin-top: 2rem;">Our Mission</h3>
            <p>To connect food lovers with their favorite restaurants and meals, making the ordering experience seamless, affordable, and enjoyable for everyone.</p>
            
            <h3 style="margin-top: 2rem;">Our Values</h3>
            <ul style="margin-left: 2rem; color: var(--gray-text);">
                <li><strong>Quality First:</strong> We partner only with restaurants that meet our high standards</li>
                <li><strong>Customer Focus:</strong> Your satisfaction is our top priority</li>
                <li><strong>Speed & Reliability:</strong> Fast delivery without compromising food quality</li>
                <li><strong>Innovation:</strong> Constantly improving our platform and services</li>
            </ul>
        </div>
    </section>

    <!-- Team Section -->
    <section class="container section-padding">
        <div class="section-header">
            <h2>Our Team</h2>
            <p>Meet the talented people behind FoodHub</p>
        </div>

        <div class="team-grid">
            <div class="team-member">
                <img src="https://source.unsplash.com/150x150/?businessman" alt="Ahmad Malove" class="team-member-image">
                <h3 class="team-member-name">Ahmad Malove</h3>
                <p class="team-member-role">Founder & CEO</p>
                <p>Visionary leader with 15+ years of experience in the food and technology industry. Ahmad founded FoodHub with a passion for improving food delivery.</p>
            </div>

            <div class="team-member">
                <img src="https://source.unsplash.com/150x150/?developer" alt="Adamu Ajida Abdalah" class="team-member-image">
                <h3 class="team-member-name">Adamu Ajida Abdalah</h3>
                <p class="team-member-role">Lead Developer</p>
                <p>Expert software engineer with a passion for building scalable solutions. Adamu leads our technical team and oversees all platform development.</p>
            </div>

            <div class="team-member">
                <img src="https://source.unsplash.com/150x150/?woman" alt="Rehema Nchimbi" class="team-member-image">
                <h3 class="team-member-name">Rehema Nchimbi</h3>
                <p class="team-member-role">Marketing Manager</p>
                <p>Creative marketing professional who brings FoodHub to life through innovative campaigns and brand storytelling.</p>
            </div>

            <div class="team-member">
                <img src="https://source.unsplash.com/150x150/?man" alt="Romelu Lukaku" class="team-member-image">
                <h3 class="team-member-name">Romelu Lukaku</h3>
                <p class="team-member-role">Customer Relations</p>
                <p>Dedicated customer service expert ensuring every customer has an amazing experience with FoodHub.</p>
            </div>
        </div>
    </section>

    <!-- Stats Section -->
    <section class="container section-padding" style="background-color: var(--light-bg); border-radius: 0.75rem;">
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 2rem; text-align: center;">
            <div>
                <h2 style="color: var(--primary-color); margin-bottom: 0.5rem;">50K+</h2>
                <p>Happy Customers</p>
            </div>
            <div>
                <h2 style="color: var(--primary-color); margin-bottom: 0.5rem;">500+</h2>
                <p>Partner Restaurants</p>
            </div>
            <div>
                <h2 style="color: var(--primary-color); margin-bottom: 0.5rem;">100K+</h2>
                <p>Orders Delivered</p>
            </div>
            <div>
                <h2 style="color: var(--primary-color); margin-bottom: 0.5rem;">4.8/5</h2>
                <p>Average Rating</p>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer>
        <div class="container">
            <div>
                <h4>🍕 FoodHub</h4>
                <p>Your trusted platform for food delivery</p>
            </div>
            <div>
                <h4>Quick Links</h4>
                <a href="/menu">Menu</a>
                <a href="/about">About Us</a>
                <a href="/contact">Contact</a>
            </div>
            <div>
                <h4>Company</h4>
                <a href="#">Privacy Policy</a>
                <a href="#">Terms of Service</a>
            </div>
            <div>
                <h4>Support</h4>
                <p>Email: support@foodhub.com</p>
                <p>Phone: +1 (555) 123-4567</p>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; 2024 FoodHub. All rights reserved.</p>
        </div>
    </footer>

    <script src="/js/app.js"></script>
</body>
</html>
